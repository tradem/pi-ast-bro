{
  "name": "pi-ast-bro",
  "version": "1.0.0-alpha.9",
  "description": "Pi extension integrating the ast-bro CLI for AST-based context saving and pre-flight syntax checks.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "test": "vitest --run",
    "typecheck": "tsc --noEmit",
    "version:alpha": "node scripts/update-version.js"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "dependencies": {
    "@earendil-works/pi-tui": "^0.80.2",
    "typebox": "^1.3.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "pi-extension",
    "ast-bro",
    "ast"
  ],
  "files": [
    "src",
    "skills",
    "package.json",
    "README.md"
  ],
  "license": "MIT"
}
